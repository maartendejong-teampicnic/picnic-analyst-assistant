# Ignore everything by default.
# Only explicitly listed files are tracked — so any new file you create
# (new agents, knowledge files, tasks, config) is automatically invisible to git.
*

# Always track the gitignore itself
!.gitignore

# Framework files
!README.md
!CLAUDE.md
!CONTEXT.md
!user-config.md.example

# Agents — only the shipped templates (new agents you create are ignored)
!agents/
!agents/ANALYST.md
!agents/ENGINEER.md
!agents/ORCHESTRATOR.md
!agents/WRITER.md
!agents/index.yaml

# Commands — only the shipped commands (new commands you create are ignored)
!commands/
!commands/add-agent.md
!commands/analyst.md
!commands/architect.md
!commands/costs.md
!commands/engineer.md
!commands/onboard-knowledge.md
!commands/perform.md
!commands/setup.md
!commands/tasks.md
!commands/writer.md

# Knowledge — only the shipped files (new knowledge files you create are ignored)
!knowledge/
!knowledge/INDEX.yaml
!knowledge/agent-common.md
!knowledge/sql-snowflake.md

# Patterns — only the shipped patterns
!patterns/
!patterns/add-agent.md
!patterns/architect.md
!patterns/onboard-knowledge.md
!patterns/setup.md

# Tools — only the shipped tools
!tools/
!tools/costs/
!tools/costs/SKILL.md
!tools/costs/costs.py

# Output folders — track skeleton only, not contents
!direct-output/
!direct-output/.gitkeep
!tasks-output/
!tasks-output/.gitkeep
