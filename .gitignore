# Allowlist — only explicitly listed files are committed to the shared repo.
# Everything else is personal/configurable and stays local.
# For already-tracked files (agents, commands, patterns): run `git update-index --skip-worktree`
# after cloning (done automatically by /setup) to hide local modifications from git status.

# Ignore everything by default
*

# Core repo files
!.gitignore
!CLAUDE.md
!CONTEXT.md
!README.md
!user-config.md.example

# Agents, commands, patterns — committed as shared starting points; personalizable after clone
!agents/
!agents/*.md
!commands/
!commands/*.md
commands/gdrive.md
!patterns/
!patterns/*.md

# Knowledge — only these two files are shared; all others are personal
!knowledge/
!knowledge/INDEX.yaml
!knowledge/sql-snowflake.md

# Context — only Picnic business vocab is shared
!context/
!context/picnic-business.md

# Tools — only costs is shared; gdrive and slides are personal
!tools/
!tools/costs/
!tools/costs/**

# Output folder skeletons — folders committed, contents gitignored
!direct/
!direct/.gitkeep
!tasks/
!tasks/.gitkeep
