# Allowlist — only explicitly listed files are committed to the shared repo.
# Everything else is personal/configurable and stays local.
#
# Two-tier model:
#   Framework files (CLAUDE.md, README.md, patterns/) — committed, tracked, do not edit.
#   Working files (agents/, commands/, context/, knowledge/, tools/) — committed as starting
#   points, then skip-worktree'd by /setup so your edits are never tracked.

# Ignore everything by default
*

# Framework — committed and tracked; do not edit
!.gitignore
!CLAUDE.md
!CONTEXT.md
!README.md
!user-config.md.example
!patterns/
!patterns/*.md

# Working files — committed as starting points; skip-worktree'd after /setup so edits stay local
!agents/
!agents/*.md
!agents/INDEX.yaml
agents/DESIGNER.md
agents/PRESENTER.md
!commands/
!commands/*.md
commands/gdrive.md
commands/designer.md
commands/presenter.md

# Knowledge — INDEX.yaml and agent-common.md are shared starting points; all other skill files are personal
!knowledge/
!knowledge/INDEX.yaml
!knowledge/agent-common.md
!knowledge/sql-snowflake.md

# Context — only Picnic business vocab is shared
!context/
!context/picnic-business.md

# Tools — only costs is shared; gdrive and slides are personal
!tools/
!tools/costs/
!tools/costs/**

# Output folder skeletons — folders committed, contents gitignored
!direct/
!direct/.gitkeep
!tasks/
!tasks/.gitkeep
